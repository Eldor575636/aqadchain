generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  INDIVIDUAL
  BUSINESS
  ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ContractType {
  MURABAHA
  MUSAWAMA
  IJARAH
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  COMPLETED
  CANCELLED
}

enum TitleStatus {
  CLEAN
  SALVAGE
  REBUILT
}

enum PaymentFrequency {
  WEEKLY
  MONTHLY
}

enum SignerRole {
  SELLER
  BUYER
}

enum ListingStatus {
  ACTIVE
  PENDING
  SOLD
  REMOVED
}

model User {
  id                   String      @id @default(uuid())
  email                String      @unique
  full_name            String
  phone                String?
  auth0_id             String      @unique
  role                 Role        @default(INDIVIDUAL)
  kyc_status           KycStatus   @default(PENDING)
  kyc_verified_at      DateTime?
  onboarding_completed Boolean     @default(false)
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  contracts        Contract[]
  audit_logs       AuditLog[]
  listings         Listing[]
  favorites        Favorite[]
  sent_messages    Message[]  @relation("sender")
  received_messages Message[] @relation("recipient")
  reviews_given    Review[]   @relation("reviewer")
  reviews_received Review[]   @relation("reviewee")
}

model Contract {
  id                  String           @id @default(uuid())
  contract_number     String           @unique
  creator_id          String
  contract_type       ContractType
  status              ContractStatus   @default(DRAFT)

  vehicle_vin         String?
  vehicle_year        Int?
  vehicle_make        String?
  vehicle_model       String?
  vehicle_trim        String?
  vehicle_mileage     Int?
  vehicle_color       String?
  title_status        TitleStatus?

  seller_name         String?
  seller_email        String?
  seller_phone        String?
  seller_address      String?

  buyer_name          String?
  buyer_email         String?
  buyer_phone         String?
  buyer_address       String?

  car_price           Decimal?         @db.Decimal(12, 2)
  down_payment        Decimal?         @db.Decimal(12, 2)
  markup_percentage   Decimal?         @db.Decimal(5, 2)
  markup_amount       Decimal?         @db.Decimal(12, 2)
  financed_amount     Decimal?         @db.Decimal(12, 2)
  apr                 Decimal?         @db.Decimal(5, 2)
  term_months         Int?
  monthly_payment     Decimal?         @db.Decimal(12, 2)
  total_payable       Decimal?         @db.Decimal(12, 2)
  payment_frequency   PaymentFrequency?
  payment_start_date  DateTime?
  late_fee_amount     Decimal?         @db.Decimal(8, 2)
  charity_name        String?
  special_terms       String?

  // Ijarah-specific fields
  ijarah_subtype      String?          // OPERATING | IMIT (lease ending with ownership transfer)
  security_deposit    Decimal?         @db.Decimal(12, 2)
  residual_value      Decimal?         @db.Decimal(12, 2) // IMIT buyout price at end of lease

  docusign_envelope_id String?
  seller_signed_at    DateTime?
  buyer_signed_at     DateTime?
  signed_pdf_url      String?

  listing_id          String?

  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  creator    User        @relation(fields: [creator_id], references: [id])
  listing    Listing?    @relation(fields: [listing_id], references: [id])
  signatures Signature[]
}

model Listing {
  id                    String         @id @default(uuid())
  seller_id             String
  status                ListingStatus  @default(ACTIVE)

  vehicle_vin           String?
  vehicle_year          Int
  vehicle_make          String
  vehicle_model         String
  vehicle_trim          String?
  vehicle_mileage       Int?
  vehicle_color         String?
  title_status          TitleStatus?

  asking_price          Decimal        @db.Decimal(12, 2)
  contract_type_offered ContractType
  description           String?
  city                  String?
  state                 String?
  zip                   String?
  latitude              Float?
  longitude             Float?
  photo_url             String?
  recalls               Json?
  has_recalls           Boolean        @default(false)

  views                 Int            @default(0)
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt

  seller    User       @relation(fields: [seller_id], references: [id])
  favorites Favorite[]
  messages  Message[]
  reviews   Review[]
  contracts Contract[]
}

model Favorite {
  id         String   @id @default(uuid())
  user_id    String
  listing_id String
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  listing Listing @relation(fields: [listing_id], references: [id])

  @@unique([user_id, listing_id])
}

model Message {
  id           String    @id @default(uuid())
  listing_id   String
  sender_id    String
  recipient_id String
  body         String
  read_at      DateTime?
  created_at   DateTime  @default(now())

  listing   Listing @relation(fields: [listing_id], references: [id])
  sender    User    @relation("sender", fields: [sender_id], references: [id])
  recipient User    @relation("recipient", fields: [recipient_id], references: [id])
}

model Review {
  id          String   @id @default(uuid())
  listing_id  String
  contract_id String
  reviewer_id String
  reviewee_id String
  rating      Int
  comment     String?
  created_at  DateTime @default(now())

  listing  Listing @relation(fields: [listing_id], references: [id])
  reviewer User    @relation("reviewer", fields: [reviewer_id], references: [id])
  reviewee User    @relation("reviewee", fields: [reviewee_id], references: [id])

  @@unique([contract_id, reviewer_id])
}

model Signature {
  id                   String     @id @default(uuid())
  contract_id          String
  signer_role          SignerRole
  signer_name          String
  signer_email         String
  signed_at            DateTime?
  ip_address           String?
  docusign_recipient_id String?
  created_at           DateTime   @default(now())

  contract Contract @relation(fields: [contract_id], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  action      String
  entity_type String?
  entity_id   String?
  metadata    Json?
  created_at  DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])
}
