{
  "name": "aqadchain-backend",
  "version": "1.0.0",
  "description": "AqadChain Halal Contract Platform - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "prisma generate --schema src/prisma/schema.prisma && node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "prisma migrate dev",
