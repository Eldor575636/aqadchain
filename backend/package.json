    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node src/prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@prisma/client": "^5.11.0",
    "@sendgrid/mail": "^8.1.3",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "docusign-esign": "^6.4.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-jwt": "^8.4.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
